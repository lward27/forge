{
  "name": "Inventory",
  "description": "Inventory management — track products, categories, warehouses, and stock levels",
  "icon": "package",
  "tables": [
    {
      "name": "categories",
      "display_field": "category_name",
      "columns": [
        {"name": "category_name", "type": "text", "nullable": false},
        {"name": "description", "type": "text"}
      ]
    },
    {
      "name": "warehouses",
      "display_field": "warehouse_name",
      "columns": [
        {"name": "warehouse_name", "type": "text", "nullable": false},
        {"name": "location", "type": "text"},
        {"name": "capacity", "type": "integer"}
      ]
    },
    {
      "name": "products",
      "display_field": "product_name",
      "columns": [
        {"name": "product_name", "type": "text", "nullable": false},
        {"name": "sku", "type": "text", "unique": true, "nullable": false},
        {"name": "description", "type": "text"},
        {"name": "price", "type": "decimal", "nullable": false},
        {"name": "cost", "type": "decimal"},
        {"name": "category_id", "type": "reference", "reference_table": "categories"},
        {"name": "is_active", "type": "boolean", "default": "true"}
      ]
    },
    {
      "name": "stock_levels",
      "display_field": null,
      "columns": [
        {"name": "quantity", "type": "integer", "nullable": false},
        {"name": "min_quantity", "type": "integer"},
        {"name": "product_id", "type": "reference", "reference_table": "products"},
        {"name": "warehouse_id", "type": "reference", "reference_table": "warehouses"}
      ]
    }
  ],
  "views": [
    {
      "table": "products",
      "name": "Active Products",
      "config": {
        "columns": [
          {"field": "id", "visible": false, "width": null},
          {"field": "product_name", "visible": true, "width": null},
          {"field": "sku", "visible": true, "width": null},
          {"field": "price", "visible": true, "width": null},
          {"field": "category_id", "visible": true, "width": null}
        ],
        "default_sort": {"field": "product_name", "direction": "asc"},
        "page_size": 25
      }
    }
  ],
  "forms": [],
  "dashboard": {
    "name": "Inventory Dashboard",
    "widgets": [
      {"type": "stat", "title": "Products", "table": "products", "w": 4, "h": 2},
      {"type": "stat", "title": "Categories", "table": "categories", "w": 4, "h": 2},
      {"type": "stat", "title": "Warehouses", "table": "warehouses", "w": 4, "h": 2},
      {"type": "view", "title": "Active Products", "table": "products", "view_name": "Active Products", "w": 12, "h": 4},
      {"type": "form", "title": "Add Product", "table": "products", "w": 6, "h": 4},
      {"type": "form", "title": "Update Stock", "table": "stock_levels", "w": 6, "h": 4}
    ]
  }
}
