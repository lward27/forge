{
  "name": "Project Tracker",
  "description": "Project management — track projects, tasks, team members, and time entries",
  "icon": "kanban",
  "tables": [
    {
      "name": "team_members",
      "display_field": "full_name",
      "columns": [
        {"name": "full_name", "type": "text", "nullable": false},
        {"name": "email", "type": "text", "unique": true},
        {"name": "team_role", "type": "text"},
        {"name": "is_active", "type": "boolean", "default": "true"}
      ]
    },
    {
      "name": "projects",
      "display_field": "project_name",
      "columns": [
        {"name": "project_name", "type": "text", "nullable": false},
        {"name": "description", "type": "text"},
        {"name": "status", "type": "text", "nullable": false},
        {"name": "start_date", "type": "date"},
        {"name": "end_date", "type": "date"},
        {"name": "owner_id", "type": "reference", "reference_table": "team_members"}
      ]
    },
    {
      "name": "tasks",
      "display_field": "task_name",
      "columns": [
        {"name": "task_name", "type": "text", "nullable": false},
        {"name": "description", "type": "text"},
        {"name": "status", "type": "text", "nullable": false},
        {"name": "priority", "type": "text"},
        {"name": "due_date", "type": "date"},
        {"name": "project_id", "type": "reference", "reference_table": "projects"},
        {"name": "assignee_id", "type": "reference", "reference_table": "team_members"}
      ]
    },
    {
      "name": "time_entries",
      "display_field": null,
      "columns": [
        {"name": "hours", "type": "decimal", "nullable": false},
        {"name": "description", "type": "text"},
        {"name": "entry_date", "type": "date", "nullable": false},
        {"name": "task_id", "type": "reference", "reference_table": "tasks"},
        {"name": "team_member_id", "type": "reference", "reference_table": "team_members"}
      ]
    }
  ],
  "views": [
    {
      "table": "tasks",
      "name": "Open Tasks",
      "config": {
        "columns": [
          {"field": "id", "visible": false, "width": null},
          {"field": "task_name", "visible": true, "width": null},
          {"field": "priority", "visible": true, "width": null},
          {"field": "status", "visible": true, "width": null},
          {"field": "due_date", "visible": true, "width": null},
          {"field": "assignee_id", "visible": true, "width": null},
          {"field": "project_id", "visible": true, "width": null}
        ],
        "default_sort": {"field": "due_date", "direction": "asc"},
        "page_size": 25
      }
    }
  ],
  "forms": [],
  "dashboard": {
    "name": "Project Dashboard",
    "widgets": [
      {"type": "stat", "title": "Projects", "table": "projects", "w": 3, "h": 2},
      {"type": "stat", "title": "Tasks", "table": "tasks", "w": 3, "h": 2},
      {"type": "stat", "title": "Team Members", "table": "team_members", "w": 3, "h": 2},
      {"type": "stat", "title": "Time Entries", "table": "time_entries", "w": 3, "h": 2},
      {"type": "view", "title": "Open Tasks", "table": "tasks", "view_name": "Open Tasks", "w": 12, "h": 4},
      {"type": "form", "title": "New Task", "table": "tasks", "w": 6, "h": 4},
      {"type": "form", "title": "Log Time", "table": "time_entries", "w": 6, "h": 4}
    ]
  }
}
